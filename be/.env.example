NODE_ENV=development
PORT=3000
APP_NAME=ECEP Backend

DB_HOST=127.0.0.1
DB_PORT=3306
DB_SOCKET_PATH=
DB_USERNAME=ecep_user
DB_PASSWORD=change_me
DB_NAME=ecep_db
DB_SYNC=true
DB_LOGGING=false

# Duong dan tuyet doi, nam ngoai source code
CERT_STORAGE_PATH=/var/company_data/certs

# Gioi han upload (bytes) - vi du 10MB
MAX_FILE_SIZE=10485760

JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7
